# Supabase (optional — enables shared workspace + Google login)
# Salin langsung dari Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Google OAuth: aktifkan di Supabase Dashboard → Authentication → Providers → Google
# Redirect URL: https://your-domain.com (dan http://localhost:5173 untuk dev)

# Migrations (Supabase CLI — jangan paste service role ke frontend):
#   npm run db:login
#   npm run db:link          # pilih project, masukkan DB password
#   npm run db:push          # apply semua file di supabase/migrations/
# Atau biarkan GitHub Action (lihat .github/workflows/supabase-migrate.yml)

# OpenAI (server-only — dipakai oleh /api/generate-plan di Vercel)
# JANGAN pakai prefix VITE_ (akan bocor di browser)
OPENAI_API_KEY=sk-...
# Sama nilai dengan VITE_SUPABASE_* di atas (dibaca API route untuk verifikasi JWT)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
